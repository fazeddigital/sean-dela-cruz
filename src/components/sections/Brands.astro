---
import { brands } from '../../lib/data';
import RevealOnScroll from '../react/RevealOnScroll';
---

<section class="brands" id="brands">
  <RevealOnScroll client:visible stagger={0.08}>
    <div class="container">
      <header class="brands-head">
        <span class="eyebrow" data-reveal>
          <span class="gold-rule"></span>The House of SPDC
        </span>
        <h2 class="display brands-title" data-reveal>
          One host.<br/>
          <em class="gold-italic">A house of six.</em>
        </h2>
        <p class="brands-lede" data-reveal>
          Every detail of an evening — the voice, the suit, the gown, the
          rentals, the 360° camera, the production — sits under one roof.
          Sean's family of brands operate as a single, coordinated team.
        </p>
      </header>

      <div class="brands-grid">
        {brands.map((b) => (
          <article class="brand-card" data-reveal>
            <div class="brand-top">
              <span class="brand-no">{b.no}</span>
              <span class="brand-accent">— {b.accent}</span>
            </div>

            <div class="brand-mark">
              <span class="brand-monogram">{b.name}</span>
              <span class="brand-sub">{b.sub}</span>
            </div>

            <p class="brand-tagline">{b.tagline}</p>

            <div class="brand-foot">
              <span class="brand-house">A House of SPDC</span>
              <span class="brand-arrow">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M2 12L12 2M12 2H4M12 2V10" stroke="currentColor" stroke-width="1.2"/>
                </svg>
              </span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </RevealOnScroll>
</section>

<style>
  .brands {
    padding: 140px 0;
    background: var(--ink);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    position: relative;
  }

  .brands::before {
    content: "VI";
    position: absolute;
    top: 80px;
    left: 6%;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 200px;
    color: var(--surface-warm);
    line-height: 1;
    z-index: 0;
    pointer-events: none;
  }

  .brands-head {
    max-width: 720px;
    margin: 0 auto 80px;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .brands-title {
    font-size: clamp(40px, 6vw, 96px);
    color: var(--bone);
    line-height: 0.95;
    margin: 24px 0 32px;
  }

  .brands-title em { font-style: italic; }

  .brands-lede {
    font-size: 17px;
    line-height: 1.7;
    color: rgba(244, 239, 230, 0.78);
    max-width: 56ch;
    margin: 0 auto;
  }

  .brands-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    position: relative;
    z-index: 1;
  }

  .brand-card {
    background: var(--surface);
    padding: 40px 36px 36px;
    display: flex;
    flex-direction: column;
    min-height: 320px;
    transition: background 0.5s var(--ease-luxe), transform 0.5s var(--ease-luxe);
    position: relative;
    overflow: hidden;
  }

  .brand-card::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    opacity: 0;
    transition: opacity 0.5s var(--ease-luxe);
  }

  .brand-card:hover {
    background: var(--surface-warm);
  }

  .brand-card:hover::after { opacity: 1; }
  .brand-card:hover .brand-arrow { color: var(--gold-bright); transform: translate(4px, -4px); }
  .brand-card:hover .brand-monogram { color: var(--gold-bright); }

  .brand-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
  }

  .brand-no {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 14px;
    color: var(--gold);
  }

  .brand-accent {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.32em;
    color: var(--muted);
  }

  .brand-mark {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 8px;
    margin: 16px 0;
  }

  .brand-monogram {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(32px, 3.6vw, 48px);
    color: var(--bone);
    letter-spacing: -0.01em;
    line-height: 1;
    transition: color 0.5s var(--ease-luxe);
  }

  .brand-sub {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 16px;
    color: var(--bone-soft);
    letter-spacing: 0.02em;
  }

  .brand-tagline {
    font-size: 14px;
    line-height: 1.6;
    color: rgba(244, 239, 230, 0.7);
    margin: 8px 0 24px;
  }

  .brand-foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--line);
    padding-top: 16px;
    margin-top: auto;
  }

  .brand-house {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.28em;
    color: var(--gold);
  }

  .brand-arrow {
    color: var(--muted);
    transition: color 0.5s var(--ease-luxe), transform 0.5s var(--ease-luxe);
  }

  @media (max-width: 960px) {
    .brands-grid { grid-template-columns: repeat(2, 1fr); }
    .brands::before { font-size: 120px; left: 4%; top: 60px; }
  }

  @media (max-width: 600px) {
    .brands-grid { grid-template-columns: 1fr; }
  }
</style>
