---
import HorizontalGallery from '../react/HorizontalGallery';
---

<section class="gallery-section" id="gallery">
  <HorizontalGallery client:visible />
</section>

<style is:global>
  .gallery-section {
    background: var(--ink);
    overflow: hidden;
  }

  .gallery-wrap {
    height: 100vh;
    width: 100%;
    position: relative;
    overflow: hidden;
  }

  .gallery-overlay-top {
    position: absolute;
    top: 100px;
    left: var(--pad);
    right: var(--pad);
    z-index: 5;
    display: flex;
    justify-content: space-between;
    align-items: center;
    pointer-events: none;
  }

  .gallery-hint {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.32em;
    color: var(--gold);
  }

  .plate-intro {
    width: clamp(360px, 32vw, 480px);
    display: flex;
    align-items: center;
    padding-left: var(--pad);
  }

  .intro-card {
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding-right: 40px;
    border-right: 1px solid var(--line);
    height: 70%;
    justify-content: center;
  }

  .gallery-title {
    font-size: clamp(36px, 4.5vw, 64px);
    color: var(--bone);
    line-height: 0.96;
  }

  .gallery-title em { font-style: italic; }

  .intro-meta {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--gold);
    font-size: 14px;
    margin-top: 8px;
  }

  .gallery-track {
    height: 100%;
    display: flex;
    align-items: center;
    gap: 40px;
    padding-left: var(--pad);
    will-change: transform;
  }

  .plate {
    flex: 0 0 auto;
    width: clamp(320px, 38vw, 520px);
    display: flex;
    flex-direction: column;
    align-self: center;
  }

  .plate-spacer {
    width: 28vw;
  }

  .plate-frame {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border: 1px solid var(--line-strong);
    background: var(--surface);
    position: relative;
  }

  .plate-frame::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 60%, rgba(14,20,16,0.5));
    pointer-events: none;
  }

  .plate-img {
    width: 110%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.1) contrast(1.05);
    will-change: transform;
  }

  .plate figcaption {
    margin-top: 18px;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    border-top: 1px solid var(--line);
    padding-top: 12px;
  }

  .plate-num {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--gold);
    font-size: 16px;
  }

  .plate-caption {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.28em;
    color: var(--bone-soft);
  }

  .plate-end {
    width: 60vw;
    padding-right: var(--pad);
  }

  .end-card {
    background: var(--surface-warm);
    border: 1px solid var(--line);
    padding: 60px 48px;
    aspect-ratio: 4 / 5;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 24px;
    text-align: center;
    align-items: center;
  }

  .end-card p {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(28px, 3vw, 42px);
    color: var(--bone);
    line-height: 1.3;
    max-width: 22ch;
  }

  .end-cta {
    margin-top: 16px;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 14px 26px;
    background: var(--gold);
    color: var(--ink);
    border-radius: 999px;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.28em;
    transition: background 0.5s var(--ease-luxe);
  }

  .end-cta:hover { background: var(--gold-bright); }

  @media (max-width: 760px) {
    .gallery-overlay {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
      top: 40px;
    }
    .gallery-title { max-width: 100%; }
    .plate { width: 78vw; }
    .plate-spacer { width: 4vw; }
  }
</style>
