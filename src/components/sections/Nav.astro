---

<nav class="nav">
  <div class="nav-inner">
    <a href="#top" class="brand">
      <span class="brand-mark">S</span>
      <span class="brand-text">
        <span class="brand-name">Sean dela Cruz</span>
        <span class="brand-sub">Host · Est. 2018</span>
      </span>
    </a>

    <ul class="links">
      <li><a href="#about">About</a></li>
      <li><a href="#services">Services</a></li>
      <li><a href="#gallery">Gallery</a></li>
      <li><a href="#brands">Brands</a></li>
      <li><a href="#reviews">Reviews</a></li>
    </ul>

    <a href="#contact" class="cta">
      <span>Book Sean</span>
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
        <path d="M2 12L12 2M12 2H4M12 2V10" stroke="currentColor" stroke-width="1.2"/>
      </svg>
    </a>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 18px var(--pad);
    background: linear-gradient(180deg, rgba(14, 20, 16, 0.92) 0%, rgba(14, 20, 16, 0) 100%);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .nav-inner {
    max-width: var(--max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 32px;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .brand-mark {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid var(--gold);
    color: var(--gold);
    display: grid;
    place-items: center;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 18px;
    line-height: 1;
  }

  .brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .brand-name {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 15px;
    letter-spacing: 0.02em;
  }

  .brand-sub {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    color: var(--muted);
    margin-top: 2px;
  }

  .links {
    list-style: none;
    display: flex;
    justify-content: center;
    gap: 36px;
  }

  .links a {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    color: var(--bone);
    opacity: 0.75;
    transition: opacity 0.4s var(--ease-luxe), color 0.4s var(--ease-luxe);
  }

  .links a:hover {
    opacity: 1;
    color: var(--gold-bright);
  }

  .cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 22px;
    border: 1px solid var(--gold);
    color: var(--gold-bright);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.28em;
    border-radius: 999px;
    transition: background 0.5s var(--ease-luxe), color 0.5s var(--ease-luxe);
  }

  .cta:hover {
    background: var(--gold);
    color: var(--ink);
  }

  .cta svg {
    transition: transform 0.5s var(--ease-luxe);
  }

  .cta:hover svg {
    transform: rotate(45deg);
  }

  @media (max-width: 980px) {
    .links { gap: 24px; }
    .links a { font-size: 11px; letter-spacing: 0.2em; }
  }

  @media (max-width: 820px) {
    .nav { padding: 14px var(--pad); }
    .links { display: none; }
    .nav-inner {
      grid-template-columns: 1fr auto;
      gap: 16px;
    }
    .brand-mark { width: 32px; height: 32px; font-size: 16px; }
    .brand-name { font-size: 13px; }
    .brand-sub { font-size: 9px; letter-spacing: 0.2em; }
    .cta {
      padding: 10px 16px;
      font-size: 10px;
      letter-spacing: 0.22em;
    }
  }

  @media (max-width: 480px) {
    .brand-sub { display: none; }
    .brand-name { font-size: 13px; line-height: 1; }
    .brand-mark { width: 30px; height: 30px; font-size: 15px; }
    .cta {
      padding: 9px 14px;
      font-size: 9px;
      letter-spacing: 0.18em;
      gap: 6px;
    }
    .cta svg { width: 11px; height: 11px; }
  }
</style>
