---
import { profile, portraitHero } from '../../lib/data';
import Marquee from './Marquee.astro';
---

<section class="hero-b" id="top">
  <div class="hero-b-bg">
    <div class="b-spot"></div>
    <div class="b-rays"></div>
    <div class="b-grid"></div>
  </div>

  <div class="hero-b-stage">
    <div class="b-marker top">
      <span class="b-meta-line">№ 001</span>
      <span class="b-meta-line">·</span>
      <span class="b-meta-line">The Iligan Host</span>
      <span class="b-meta-line">·</span>
      <span class="b-meta-line">Vol. IV</span>
    </div>

    <h1 class="display b-name-top">
      <span class="b-mask"><span class="b-line">SEAN</span></span>
    </h1>

    <div class="b-portrait-wrap">
      <div class="b-portrait-glow"></div>
      <div class="b-portrait-frame">
        <img
          src={portraitHero}
          alt="Sean Sajonia dela Cruz"
          loading="eager"
          onerror="this.onerror=null;this.src='https://images.unsplash.com/photo-1542327897-d73f4005b533?w=900&q=80&auto=format&fit=crop';"
        />
      </div>

      <span class="b-side-text left">— Iligan, PH</span>
      <span class="b-side-text right">Est. {profile.hostingSince}</span>
    </div>

    <h2 class="display b-name-bottom">
      <span class="b-mask"><span class="b-line gold-italic">dela&nbsp;Cruz</span></span>
    </h2>

    <p class="b-tagline">
      <span class="rule"></span>
      <span class="text">Wedding & Events Host</span>
      <span class="rule"></span>
    </p>

    <p class="b-lede">
      Iligan City's premier host. Booked across the Philippines and Singapore.
      A composed presence on the mic — and a quiet engine behind every transition.
    </p>

    <div class="b-actions">
      <a href="#contact" class="b-cta">
        <span>Reserve a Date</span>
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M2 12L12 2M12 2H4M12 2V10" stroke="currentColor" stroke-width="1.2"/>
        </svg>
      </a>
      <a href="#gallery" class="b-ghost">View Highlights</a>
    </div>
  </div>

  <div class="b-corner-meta tl">
    <span class="b-tiny">Plate I</span>
    <span class="b-tiny">Featured · 2026</span>
  </div>
  <div class="b-corner-meta tr">
    <span class="b-tiny">A House of</span>
    <span class="b-tiny gold">SPDC</span>
  </div>
  <div class="b-corner-meta bl">
    <span class="b-tiny">11 Cities</span>
    <span class="b-tiny">80K Following</span>
  </div>
  <div class="b-corner-meta br">
    <span class="b-tiny">100%</span>
    <span class="b-tiny">Recommend</span>
  </div>
</section>

<Marquee />

<script>
  import gsap from 'gsap';

  const run = () => {
    gsap.set('.b-line', { yPercent: 110 });
    gsap.set('.b-portrait-frame', { scale: 0.85, opacity: 0 });
    gsap.set('.b-portrait-glow', { scale: 0.5, opacity: 0 });
    gsap.set('.b-tagline .rule', { scaleX: 0 });
    gsap.set(['.b-meta-line', '.b-side-text', '.b-tagline .text', '.b-lede', '.b-actions', '.b-corner-meta'], {
      opacity: 0, y: 14
    });

    const tl = gsap.timeline({ defaults: { ease: 'expo.out' } });

    tl.to('.b-meta-line', { opacity: 1, y: 0, duration: 0.8, stagger: 0.05, delay: 0.2 })
      .to('.b-name-top .b-line', { yPercent: 0, duration: 1.3 }, '<0.1')
      .to('.b-portrait-glow', { scale: 1, opacity: 1, duration: 1.6, ease: 'power3.out' }, '<0.05')
      .to('.b-portrait-frame', { scale: 1, opacity: 1, duration: 1.4, ease: 'power3.out' }, '<0.1')
      .to('.b-side-text', { opacity: 1, y: 0, duration: 1, stagger: 0.1 }, '<0.5')
      .to('.b-name-bottom .b-line', { yPercent: 0, duration: 1.3 }, '<0.05')
      .to('.b-tagline .rule', { scaleX: 1, duration: 1, transformOrigin: 'center', ease: 'power3.out' }, '<0.1')
      .to('.b-tagline .text', { opacity: 1, y: 0, duration: 0.8 }, '<0.2')
      .to('.b-lede', { opacity: 1, y: 0, duration: 0.9 }, '<0.1')
      .to('.b-actions', { opacity: 1, y: 0, duration: 0.9 }, '<0.1')
      .to('.b-corner-meta', { opacity: 1, y: 0, duration: 0.9, stagger: 0.08 }, '<0');

    // Slow rotating rays behind the spotlight
    gsap.to('.b-rays', {
      rotation: 360,
      duration: 80,
      ease: 'none',
      repeat: -1,
      transformOrigin: 'center center',
    });

    // Floating portrait
    gsap.to('.b-portrait-frame', {
      y: -10,
      duration: 4.5,
      ease: 'sine.inOut',
      repeat: -1,
      yoyo: true,
      delay: 2.5,
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', run);
  } else {
    run();
  }
</script>

<style>
  .hero-b {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    padding: 110px var(--pad) 80px;
    isolation: isolate;
  }

  /* Background — radial spotlight */
  .hero-b-bg { position: absolute; inset: 0; z-index: -1; }

  .b-spot {
    position: absolute;
    width: 90vw;
    height: 90vw;
    max-width: 1100px;
    max-height: 1100px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background:
      radial-gradient(circle, rgba(200, 166, 100, 0.22) 0%, rgba(200, 166, 100, 0.06) 35%, rgba(200, 166, 100, 0) 70%);
    filter: blur(40px);
  }

  .b-rays {
    position: absolute;
    width: 1400px;
    height: 1400px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background:
      conic-gradient(
        from 0deg,
        transparent 0deg,
        rgba(200, 166, 100, 0.04) 30deg,
        transparent 60deg,
        rgba(200, 166, 100, 0.05) 120deg,
        transparent 150deg,
        rgba(200, 166, 100, 0.03) 240deg,
        transparent 270deg,
        rgba(200, 166, 100, 0.04) 330deg,
        transparent 360deg
      );
    opacity: 0.7;
  }

  .b-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--line) 1px, transparent 1px),
      linear-gradient(90deg, var(--line) 1px, transparent 1px);
    background-size: 88px 88px;
    mask-image: radial-gradient(ellipse at center, black 0%, transparent 65%);
    opacity: 0.3;
  }

  /* Stage — centered column */
  .hero-b-stage {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
    position: relative;
    z-index: 2;
    padding-top: 32px;
  }

  /* Top metadata */
  .b-marker.top {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 14px;
    margin-bottom: 32px;
  }

  .b-meta-line {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.32em;
    color: var(--gold);
  }

  .b-meta-line:nth-child(2),
  .b-meta-line:nth-child(4) {
    color: var(--muted);
  }

  /* Names — top and bottom of portrait */
  .b-name-top, .b-name-bottom {
    font-size: clamp(64px, 12vw, 180px);
    line-height: 0.85;
    color: var(--bone);
    letter-spacing: -0.04em;
    font-weight: 300;
  }

  .b-name-top {
    margin-bottom: -36px;
    text-transform: uppercase;
    font-variation-settings: "opsz" 144, "SOFT" 30;
  }

  .b-name-bottom {
    margin-top: -42px;
    z-index: 3;
    position: relative;
  }

  .b-mask {
    display: block;
    overflow: hidden;
  }

  .b-line {
    display: block;
    will-change: transform;
  }

  /* Portrait — centered, large, with glow */
  .b-portrait-wrap {
    position: relative;
    width: clamp(280px, 36vw, 460px);
    aspect-ratio: 3 / 4;
    margin: 0 auto;
    z-index: 2;
  }

  .b-portrait-glow {
    position: absolute;
    inset: -40px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(200, 166, 100, 0.4) 0%, rgba(200, 166, 100, 0) 70%);
    filter: blur(30px);
    z-index: -1;
  }

  .b-portrait-frame {
    width: 100%;
    height: 100%;
    overflow: hidden;
    border: 1px solid var(--line-strong);
    background: #6a4a2c;
    box-shadow:
      0 30px 80px rgba(0, 0, 0, 0.6),
      0 0 0 8px rgba(200, 166, 100, 0.04),
      0 0 0 9px rgba(200, 166, 100, 0.15);
    will-change: transform, opacity;
  }

  .b-portrait-frame img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: contrast(1.02) saturate(1.04);
  }

  .b-side-text {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-display);
    font-style: italic;
    font-size: 13px;
    color: var(--muted);
    letter-spacing: 0.04em;
    writing-mode: vertical-rl;
    white-space: nowrap;
  }

  .b-side-text.left { left: -32px; transform: translateY(-50%) rotate(180deg); }
  .b-side-text.right { right: -32px; }

  /* Tagline */
  .b-tagline {
    margin: 28px auto 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
  }

  .b-tagline .rule {
    flex: 0 0 56px;
    height: 1px;
    background: var(--gold);
    transform-origin: center;
  }

  .b-tagline .text {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.36em;
    color: var(--gold-bright);
    white-space: nowrap;
  }

  /* Lede */
  .b-lede {
    max-width: 56ch;
    margin: 0 auto 36px;
    font-size: 16px;
    line-height: 1.7;
    color: rgba(244, 239, 230, 0.78);
  }

  /* Actions */
  .b-actions {
    display: flex;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .b-cta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 16px 28px;
    background: var(--gold);
    color: var(--ink);
    border-radius: 999px;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.28em;
    font-weight: 500;
    transition: background 0.5s var(--ease-luxe), transform 0.5s var(--ease-luxe);
  }

  .b-cta:hover { background: var(--gold-bright); transform: translateY(-2px); }
  .b-cta:hover svg { transform: rotate(45deg); }
  .b-cta svg { transition: transform 0.5s var(--ease-luxe); }

  .b-ghost {
    display: inline-flex;
    align-items: center;
    padding: 16px 6px;
    color: var(--bone);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.28em;
    border-bottom: 1px solid var(--line-strong);
    transition: color 0.4s var(--ease-luxe), border-color 0.4s var(--ease-luxe);
  }

  .b-ghost:hover { color: var(--gold-bright); border-color: var(--gold); }

  /* Corner metadata */
  .b-corner-meta {
    position: absolute;
    display: flex;
    flex-direction: column;
    gap: 4px;
    z-index: 4;
  }

  .b-corner-meta.tl { top: 110px; left: var(--pad); align-items: flex-start; }
  .b-corner-meta.tr { top: 110px; right: var(--pad); align-items: flex-end; }
  .b-corner-meta.bl { bottom: 60px; left: var(--pad); align-items: flex-start; }
  .b-corner-meta.br { bottom: 60px; right: var(--pad); align-items: flex-end; }

  .b-tiny {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.28em;
    color: var(--muted);
  }

  .b-tiny.gold {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--gold);
    text-transform: none;
    letter-spacing: 0.02em;
    font-size: 14px;
  }

  /* Responsive */
  @media (max-width: 820px) {
    .hero-b { padding: 100px var(--pad) 60px; min-height: auto; }
    .b-name-top, .b-name-bottom { font-size: clamp(48px, 14vw, 90px); }
    .b-name-top { margin-bottom: -22px; }
    .b-name-bottom { margin-top: -24px; }
    .b-portrait-wrap { width: clamp(220px, 60vw, 340px); }
    .b-side-text { display: none; }
    .b-corner-meta { display: none; }
    .b-marker.top { gap: 8px; flex-wrap: wrap; }
    .b-meta-line { font-size: 9px; letter-spacing: 0.24em; }
    .b-tagline .rule { flex: 0 0 32px; }
    .b-tagline .text { font-size: 10px; letter-spacing: 0.28em; }
    .b-lede { font-size: 14px; }
    .b-cta, .b-ghost { padding: 13px 20px; font-size: 11px; letter-spacing: 0.22em; }
  }
</style>
